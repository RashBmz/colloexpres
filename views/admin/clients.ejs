<%- include('../partials/head', { title: 'Clients', bodyClass: 'page-app' }) %>
<div class="app-layout">
  <header class="top-bar">
    <a href="/admin/dashboard" class="back-btn">← Admin</a>
    <h1 class="page-title">Clients (<%= clients.length %>)</h1>
  </header>
  <div style="padding:16px 16px 100px">
    <% clients.forEach(c => { %>
    <div class="livreur-full-card">
      <div style="display:flex;align-items:center;gap:14px">
        <div class="livreur-av" style="background:linear-gradient(135deg,#4fc3f7,#0277bd)"><%= c.name[0] %></div>
        <div>
          <div class="livreur-row-name"><%= c.name %></div>
          <div class="livreur-row-stats">📞 <%= c.phone %> · <%= c.order_count %> commande(s)</div>
          <div class="livreur-row-stats">Inscrit le <%= new Date(c.created_at).toLocaleDateString('fr-FR') %></div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <%- include('../partials/bottom-nav', { navItems: [
    { href: '/admin/dashboard', icon: '📊', label: 'Stats', active: false },
    { href: '/admin/commandes', icon: '📦', label: 'Commandes', active: false },
    { href: '/admin/livreurs', icon: '🛵', label: 'Livreurs', active: false },
    { href: '/auth/logout', icon: '↩', label: 'Déco', active: false },
  ]}) %>
</div>
</body></html>
