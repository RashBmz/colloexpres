<%- include('../partials/head', { title: 'Restaurants', bodyClass: 'page-app page-admin-restaurants' }) %>
<%- include('../partials/flash') %>
<style>
.resto-admin-wrap { padding: 14px 14px 110px; display: grid; gap: 14px; }
.resto-admin-hero {
  background: linear-gradient(135deg, rgba(255,92,26,0.14), rgba(79,195,247,0.07));
  border: 1px solid rgba(255,255,255,0.09);
  border-radius: 18px;
  padding: 16px;
}
.resto-admin-kicker { color: var(--accent2); font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
.resto-admin-title { font-size: 22px; font-weight: 900; margin-top: 5px; line-height: 1.1; }
.resto-admin-copy { color: var(--text2); font-size: 13px; line-height: 1.5; margin-top: 8px; }
.resto-panel {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 18px;
  overflow: clip;
}
.resto-panel-head {
  padding: 14px;
  border-bottom: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
}
.resto-panel-title { font-weight: 900; font-size: 16px; }
.resto-panel-sub { color: var(--muted); font-size: 12px; line-height: 1.45; margin-top: 3px; }
.resto-panel-body { padding: 14px; display: grid; gap: 12px; }
.resto-step {
  border: 1px solid var(--border);
  border-radius: 14px;
  background: rgba(255,255,255,0.025);
  padding: 12px;
}
.resto-step-title { display: flex; align-items: center; gap: 8px; font-weight: 900; margin-bottom: 10px; }
.resto-step-num {
  width: 24px; height: 24px; border-radius: 50%;
  background: rgba(255,92,26,0.15);
  color: var(--accent);
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 900;
}
.resto-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 9px; }
.resto-grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 9px; }
.field-help { color: var(--muted); font-size: 11px; line-height: 1.35; margin-top: -2px; }
.preset-row { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 8px; }
.preset-btn, .small-action {
  min-height: 40px;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: rgba(255,255,255,0.035);
  color: var(--text);
  font-weight: 800;
  padding: 0 10px;
}
.preset-btn:hover, .small-action:hover { border-color: rgba(255,92,26,0.45); color: var(--accent); }
.small-action.accent { background: rgba(255,92,26,0.13); border-color: rgba(255,92,26,0.28); color: var(--accent); }
.small-action.danger { color: var(--red); border-color: rgba(255,68,68,0.28); }
.menu-workspace { display: grid; gap: 10px; }
.menu-summary {
  display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 8px;
}
.summary-pill {
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 10px;
  background: var(--surface);
}
.summary-num { font-family: var(--font-d); color: var(--accent); font-size: 28px; line-height: 1; }
.summary-label { color: var(--muted); font-size: 11px; margin-top: 3px; }
.cat-card {
  border: 1px solid var(--border);
  border-radius: 16px;
  background: var(--surface);
  padding: 12px;
  display: grid;
  gap: 10px;
}
.cat-head { display: grid; grid-template-columns: 1fr auto; gap: 8px; align-items: start; }
.cat-fields { display: grid; grid-template-columns: 1fr 150px; gap: 8px; }
.item-card {
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 14px;
  background: rgba(0,0,0,0.15);
  padding: 10px;
  display: grid;
  gap: 8px;
}
.item-main { display: grid; grid-template-columns: 1fr 105px auto; gap: 8px; align-items: start; }
.item-extra { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.option-card {
  border: 1px dashed rgba(255,255,255,0.18);
  border-radius: 13px;
  padding: 10px;
  display: grid;
  gap: 8px;
}
.option-main { display: grid; grid-template-columns: 1fr 120px 105px auto; gap: 8px; align-items: start; }
.choice-row { display: grid; grid-template-columns: 1fr 90px auto; gap: 8px; align-items: start; }
.builder-empty {
  border: 1px dashed var(--border);
  border-radius: 14px;
  color: var(--muted);
  padding: 14px;
  text-align: center;
  font-size: 13px;
}
.builder-label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 0.8px; font-weight: 900; }
.checkline { display: flex; gap: 7px; align-items: center; min-height: 40px; color: var(--text2); font-size: 12px; }
.checkline input { width: 16px; height: 16px; flex-shrink: 0; }
.menu-json-input { display: none; }
.resto-card-admin {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: clip;
}
.resto-row {
  display: grid;
  grid-template-columns: 58px 1fr auto;
  gap: 12px;
  align-items: center;
  padding: 12px;
}
.resto-thumb {
  width: 58px; height: 58px; border-radius: 14px;
  object-fit: cover; background: var(--surface);
  border: 1px solid var(--border);
}
.resto-name { font-weight: 900; overflow-wrap: anywhere; }
.resto-meta { color: var(--muted); font-size: 12px; line-height: 1.45; margin-top: 3px; }
.resto-status {
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 5px 9px;
  font-size: 11px;
  color: var(--muted);
  white-space: nowrap;
}
.resto-status.open { color: var(--green); border-color: rgba(0,230,118,0.35); background: rgba(0,230,118,0.08); }
.resto-status.closed { color: var(--red); border-color: rgba(255,68,68,0.35); background: rgba(255,68,68,0.08); }
.resto-edit { padding: 0 12px 12px; }
.resto-edit summary { list-style: none; }
.resto-edit summary::-webkit-details-marker { display: none; }
.delete-form { margin-top: 10px; }
.sticky-save {
  position: sticky;
  bottom: calc(76px + env(safe-area-inset-bottom));
  z-index: 20;
  background: rgba(9,9,16,0.86);
  padding-top: 8px;
  backdrop-filter: blur(12px);
}
@media (max-width: 520px) {
  .resto-admin-wrap { padding: 10px 10px 105px; }
  .resto-panel-head { flex-direction: column; }
  .resto-grid, .resto-grid-3, .preset-row, .menu-summary, .cat-fields, .item-main, .item-extra, .option-main, .choice-row { grid-template-columns: 1fr; }
  .cat-head { grid-template-columns: 1fr; }
  .small-action, .preset-btn { width: 100%; }
  .resto-row { grid-template-columns: 48px 1fr; align-items: start; }
  .resto-thumb { width: 48px; height: 48px; }
  .resto-status { grid-column: 2; justify-self: start; }
}
</style>

<div class="app-layout">
  <header class="top-bar">
    <a href="/admin/dashboard" class="back-btn">← Admin</a>
    <h1 class="page-title">Restaurants</h1>
  </header>

  <main class="resto-admin-wrap">
    <section class="resto-admin-hero">
      <div class="resto-admin-kicker">Gestion rapide</div>
      <div class="resto-admin-title">Ajoute un restaurant complet sans toucher au code</div>
      <div class="resto-admin-copy">Remplis les infos, charge un modele de carte, modifie les noms/prix/options, puis enregistre. Les clients verront directement le restaurant dans l'app.</div>
    </section>

    <section class="resto-panel">
      <div class="resto-panel-head">
        <div>
          <div class="resto-panel-title">Nouveau restaurant</div>
          <div class="resto-panel-sub">Le plus rapide: choisis un modele, remplace les articles par ceux du restaurant, et publie.</div>
        </div>
      </div>
      <form action="/admin/restaurants" method="POST" class="restaurant-form resto-panel-body">
        <%- include('restaurant-form-fields', { restaurant: null }) %>
        <div class="resto-step">
          <div class="resto-step-title"><span class="resto-step-num">2</span> Carte du restaurant</div>
          <div class="preset-row">
            <button class="preset-btn" type="button" data-preset="fastfood">Fast-food</button>
            <button class="preset-btn" type="button" data-preset="pizza">Pizza</button>
            <button class="preset-btn" type="button" data-preset="tacos">Tacos</button>
            <button class="preset-btn" type="button" data-preset="cafe">Cafe</button>
          </div>
          <div class="field-help">Tu peux garder les categories pre-remplies, modifier les articles, puis ajouter des supplements comme fromage, taille, sauce ou boisson.</div>
          <div class="menu-builder" data-menu-builder data-default-preset="fastfood"></div>
          <textarea class="menu-json-input" name="menu_json" required>{}</textarea>
        </div>
        <div class="sticky-save">
          <button type="submit" class="btn-primary btn-full btn-lg">Enregistrer le restaurant</button>
        </div>
      </form>
    </section>

    <section class="resto-panel">
      <div class="resto-panel-head">
        <div>
          <div class="resto-panel-title">Restaurants existants (<%= restaurants.length %>)</div>
          <div class="resto-panel-sub">Ouvre un restaurant pour modifier ses infos ou sa carte.</div>
        </div>
      </div>
      <div class="resto-panel-body">
        <% if (restaurants.length === 0) { %>
          <div class="builder-empty">Aucun restaurant pour le moment.</div>
        <% } %>
        <% restaurants.forEach((restaurant) => { %>
          <article class="resto-card-admin">
            <div class="resto-row">
              <img class="resto-thumb" src="<%= restaurant.image || restaurant.coverImage || '/images/icons/icon-192.png' %>" alt="<%= restaurant.name %>" loading="lazy">
              <div>
                <div class="resto-name"><%= restaurant.name %></div>
                <div class="resto-meta"><%= restaurant.category || 'Sans categorie' %> · <%= restaurant.deliveryFee %> DA livraison · min <%= restaurant.minOrder %> DA<br>ID: <%= restaurant.id %></div>
              </div>
              <span class="resto-status <%= restaurant.open ? 'open' : 'closed' %>"><%= restaurant.open ? 'Ouvert' : 'Ferme' %></span>
            </div>
            <details class="resto-edit">
              <summary class="btn-outline btn-full">Modifier</summary>
              <form action="/admin/restaurants/<%= restaurant.id %>/modifier" method="POST" class="restaurant-form" style="margin-top:12px;display:grid;gap:12px">
                <%- include('restaurant-form-fields', { restaurant }) %>
                <div class="resto-step">
                  <div class="resto-step-title"><span class="resto-step-num">2</span> Carte du restaurant</div>
                  <div class="preset-row">
                    <button class="preset-btn" type="button" data-preset="fastfood">Fast-food</button>
                    <button class="preset-btn" type="button" data-preset="pizza">Pizza</button>
                    <button class="preset-btn" type="button" data-preset="tacos">Tacos</button>
                    <button class="preset-btn" type="button" data-preset="cafe">Cafe</button>
                  </div>
                  <div class="menu-builder" data-menu-builder></div>
                  <textarea class="menu-json-input" name="menu_json" required><%= formatMenuJson(restaurant.menu) %></textarea>
                </div>
                <button type="submit" class="btn-primary btn-full">Enregistrer les modifications</button>
              </form>
              <form action="/admin/restaurants/<%= restaurant.id %>/supprimer" method="POST" class="delete-form">
                <button type="submit" class="btn-danger-sm" onclick="return confirm('Supprimer <%= restaurant.name %> ?')">Supprimer ce restaurant</button>
              </form>
            </details>
          </article>
        <% }) %>
      </div>
    </section>
  </main>

  <%- include('../partials/bottom-nav', { navItems: [
    { href: '/admin/dashboard', icon: '📊', label: 'Stats', active: false },
    { href: '/admin/commandes', icon: '📦', label: 'Cmdes', active: false },
    { href: '/admin/restaurants', icon: '🍔', label: 'Restos', active: true },
    { href: '/admin/livreurs', icon: '🛵', label: 'Livreurs', active: false },
    { href: '/auth/logout', icon: '↩', label: 'Deco', active: false },
  ]}) %>
</div>

<script>
(function() {
  const builders = new WeakMap();

  const PRESETS = {
    fastfood: {
      tacos: { label: 'Tacos', items: [
        item('tacos-simple', 'Tacos Simple', 450, 'Tacos, frites, sauce au choix', 'https://commons.wikimedia.org/wiki/Special:FilePath/Tacos.jpg', [
          choiceOption('viande', 'Viande', true, [['poulet','Poulet',0], ['viande-hachee','Viande hachee',0], ['mixte','Mixte',50]]),
          choiceOption('sauce', 'Sauce', false, [['blanche','Blanche',0], ['harissa','Harissa',0], ['algerienne','Algerienne',0]]),
          checkOption('gratine', 'Gratine fromage', 50),
        ]),
        item('tacos-double', 'Tacos Double', 600, 'Double viande, frites, fromage', 'https://commons.wikimedia.org/wiki/Special:FilePath/Tacos.jpg', [])
      ]},
      pizzas: { label: 'Pizza', items: [
        item('pizza-margherita', 'Pizza Margherita', 600, 'Sauce tomate, fromage', 'https://commons.wikimedia.org/wiki/Special:FilePath/Pizza_food.jpg', [
          choiceOption('taille', 'Taille', true, [['moyenne','Moyenne',0], ['grande','Grande',150], ['xl','XL',300]])
        ])
      ]},
      hamburgers: { label: 'Hamburgers', items: [
        item('burger-classic', 'Burger Classic', 400, 'Steak, fromage, salade, sauce', 'https://commons.wikimedia.org/wiki/Special:FilePath/Hamburger_(black_bg).jpg', [
          choiceOption('viande', 'Viande', true, [['steak','Steak',0], ['poulet','Poulet',0], ['double','Double steak',180]]),
          checkOption('fromage', 'Fromage extra', 50)
        ])
      ]}
    },
    pizza: {
      pizzas: { label: 'Pizzas', items: [
        item('pizza-reine', 'Pizza Reine', 650, 'Tomate, fromage, champignons', 'https://commons.wikimedia.org/wiki/Special:FilePath/Pizza_food.jpg', [
          choiceOption('taille', 'Taille', true, [['m','Moyenne',0], ['g','Grande',150], ['xl','XL',300]]),
          choiceOption('supplement', 'Supplement', false, [['fromage','Fromage',80], ['thon','Thon',120], ['poulet','Poulet',150]])
        ]),
        item('pizza-orientale', 'Pizza Orientale', 700, 'Merguez, poivrons, fromage', 'https://commons.wikimedia.org/wiki/Special:FilePath/Pizza_food.jpg', [])
      ]},
      boissons: { label: 'Boissons', items: [item('boisson-33cl', 'Boisson 33cl', 100, 'Au choix', '', [choiceOption('boisson', 'Boisson', true, [['coca','Coca',0], ['fanta','Fanta',0], ['eau','Eau',0]])])] }
    },
    tacos: {
      tacos: { label: 'Tacos', items: [
        item('tacos-simple', 'Tacos Simple', 450, 'Une viande, frites, sauce', 'https://commons.wikimedia.org/wiki/Special:FilePath/Tacos.jpg', [
          choiceOption('viande', 'Viande', true, [['poulet','Poulet',0], ['viande','Viande hachee',0], ['kebda','Kebda',0]]),
          choiceOption('sauce', 'Sauce', true, [['blanche','Blanche',0], ['harissa','Harissa',0], ['bbq','BBQ',0]]),
          checkOption('gratine', 'Gratine', 50)
        ]),
        item('tacos-maxi', 'Tacos Maxi', 750, 'Format XXL', 'https://commons.wikimedia.org/wiki/Special:FilePath/Tacos.jpg', [])
      ]},
      menus: { label: 'Menus', items: [item('menu-tacos', 'Menu Tacos + Boisson', 600, 'Tacos, frites, boisson', '', [])] }
    },
    cafe: {
      boissons: { label: 'Boissons', items: [
        item('cafe', 'Cafe', 80, 'Cafe noir', '', []),
        item('jus', 'Jus frais', 180, 'Jus selon disponibilite', '', [choiceOption('fruit', 'Fruit', true, [['orange','Orange',0], ['citron','Citron',0], ['fraise','Fraise',80]])])
      ]},
      desserts: { label: 'Desserts', items: [item('crepe', 'Crepe Nutella', 300, 'Crepe sucree', '', [checkOption('banane', 'Ajouter banane', 60)])] }
    }
  };

  function item(id, name, price, description, image, options) {
    const optionObject = {};
    options.forEach((opt) => { optionObject[opt.key] = opt.value; });
    return { id, name, basePrice: price, description, image, options: optionObject };
  }
  function choiceOption(key, label, required, choices) {
    return { key, value: { label, required, choices: choices.map((row) => ({ id: row[0], label: row[1], price: row[2] })) } };
  }
  function checkOption(key, label, price) {
    return { key, value: { label, required: false, type: 'checkbox', price } };
  }
  function slugify(value) {
    return String(value || 'item').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 60) || 'item';
  }
  function esc(value) {
    return String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' })[char]);
  }
  function menuToState(menu) {
    return Object.entries(menu || {}).map(([key, cat]) => ({
      key: slugify(key),
      label: String(cat?.label || key || 'Categorie'),
      items: Array.isArray(cat?.items) ? cat.items.map(itemToState) : [],
    }));
  }
  function itemToState(raw) {
    return {
      id: String(raw?.id || slugify(raw?.name || 'article')),
      name: String(raw?.name || ''),
      basePrice: Number(raw?.basePrice || 0),
      description: String(raw?.description || ''),
      image: String(raw?.image || ''),
      options: Object.entries(raw?.options || {}).map(([key, opt]) => ({
        key: slugify(key),
        label: String(opt?.label || key),
        type: opt?.type === 'checkbox' ? 'checkbox' : 'choices',
        required: Boolean(opt?.required),
        price: Number(opt?.price || 0),
        choices: Array.isArray(opt?.choices) ? opt.choices.map((choice) => ({ id: String(choice.id || slugify(choice.label)), label: String(choice.label || ''), price: Number(choice.price || 0) })) : [],
      })),
    };
  }
  function stateToMenu(state) {
    const menu = {};
    state.categories.forEach((cat, catIndex) => {
      const catKey = slugify(cat.key || cat.label || 'categorie-' + (catIndex + 1));
      menu[catKey] = { label: cat.label || catKey, items: cat.items.map((row, itemIndex) => {
        const options = {};
        row.options.forEach((opt, optIndex) => {
          const key = slugify(opt.key || opt.label || 'option-' + (optIndex + 1));
          options[key] = opt.type === 'checkbox'
            ? { label: opt.label || key, required: Boolean(opt.required), type: 'checkbox', price: Number(opt.price || 0) }
            : { label: opt.label || key, required: Boolean(opt.required), choices: opt.choices.map((choice, choiceIndex) => ({ id: slugify(choice.id || choice.label || 'choix-' + (choiceIndex + 1)), label: choice.label || 'Choix', price: Number(choice.price || 0) })) };
        });
        return { id: slugify(row.id || row.name || 'article-' + (itemIndex + 1)), name: row.name || 'Article', basePrice: Number(row.basePrice || 0), description: row.description || '', image: row.image || '', options };
      }) };
    });
    return menu;
  }
  function sync(builder) {
    const state = builders.get(builder);
    state.textarea.value = JSON.stringify(stateToMenu(state), null, 2);
  }
  function stats(state) {
    const categories = state.categories.length;
    const items = state.categories.reduce((sum, cat) => sum + cat.items.length, 0);
    const options = state.categories.reduce((sum, cat) => sum + cat.items.reduce((n, item) => n + item.options.length, 0), 0);
    return { categories, items, options };
  }
  function render(builder) {
    const state = builders.get(builder);
    const s = stats(state);
    builder.innerHTML = [
      '<div class="menu-workspace">',
      '<div class="menu-summary">',
      summary(s.categories, 'Categories'),
      summary(s.items, 'Articles'),
      summary(s.options, 'Options'),
      '</div>',
      '<div style="display:flex;gap:8px;flex-wrap:wrap">',
      '<button class="small-action accent" type="button" data-action="add-cat">+ Ajouter une categorie</button>',
      '</div>',
      state.categories.length ? state.categories.map(renderCategory).join('') : '<div class="builder-empty">Aucune categorie. Clique sur un modele ou ajoute une categorie.</div>',
      '</div>'
    ].join('');
    sync(builder);
  }
  function summary(num, label) {
    return '<div class="summary-pill"><div class="summary-num">' + num + '</div><div class="summary-label">' + label + '</div></div>';
  }
  function renderCategory(cat, catIndex) {
    return '<section class="cat-card" data-cat="' + catIndex + '">' +
      '<div class="cat-head"><div class="cat-fields">' +
      input('Nom categorie', cat.label, { field: 'label', cat: catIndex }) +
      input('Cle', cat.key, { field: 'key', cat: catIndex }) +
      '</div><button class="small-action danger" type="button" data-action="remove-cat" data-cat="' + catIndex + '">Supprimer</button></div>' +
      '<div class="builder-label">Articles de cette categorie</div>' +
      (cat.items.length ? cat.items.map((row, itemIndex) => renderItem(row, catIndex, itemIndex)).join('') : '<div class="builder-empty">Aucun article ici.</div>') +
      '<button class="small-action accent" type="button" data-action="add-item" data-cat="' + catIndex + '">+ Ajouter un article</button>' +
    '</section>';
  }
  function renderItem(row, catIndex, itemIndex) {
    return '<div class="item-card">' +
      '<div class="item-main">' +
      input('Nom article', row.name, { field: 'name', cat: catIndex, item: itemIndex }) +
      input('Prix DA', row.basePrice, { field: 'basePrice', cat: catIndex, item: itemIndex, type: 'number' }) +
      '<button class="small-action danger" type="button" data-action="remove-item" data-cat="' + catIndex + '" data-item="' + itemIndex + '">Suppr.</button>' +
      '</div>' +
      '<div class="item-extra">' + input('Description courte', row.description, { field: 'description', cat: catIndex, item: itemIndex }) + input('ID article', row.id, { field: 'id', cat: catIndex, item: itemIndex }) + '</div>' +
      input('Image URL optionnelle', row.image, { field: 'image', cat: catIndex, item: itemIndex, type: 'url' }) +
      '<div class="builder-label">Options / supplements</div>' +
      (row.options.length ? row.options.map((opt, optIndex) => renderOption(opt, catIndex, itemIndex, optIndex)).join('') : '<div class="builder-empty">Pas d option. Exemple: taille, viande, sauce, supplement fromage.</div>') +
      '<button class="small-action" type="button" data-action="add-option" data-cat="' + catIndex + '" data-item="' + itemIndex + '">+ Ajouter option</button>' +
    '</div>';
  }
  function renderOption(opt, catIndex, itemIndex, optIndex) {
    const choices = opt.type === 'checkbox'
      ? input('Prix supplement', opt.price, { field: 'price', cat: catIndex, item: itemIndex, option: optIndex, type: 'number' })
      : opt.choices.map((choice, choiceIndex) => '<div class="choice-row">' + input('Choix', choice.label, { field: 'label', cat: catIndex, item: itemIndex, option: optIndex, choice: choiceIndex }) + input('Prix +', choice.price, { field: 'price', cat: catIndex, item: itemIndex, option: optIndex, choice: choiceIndex, type: 'number' }) + '<button class="small-action danger" type="button" data-action="remove-choice" data-cat="' + catIndex + '" data-item="' + itemIndex + '" data-option="' + optIndex + '" data-choice="' + choiceIndex + '">Suppr.</button></div>').join('');
    return '<div class="option-card">' +
      '<div class="option-main">' +
      input('Nom option', opt.label, { field: 'label', cat: catIndex, item: itemIndex, option: optIndex }) +
      '<select class="field-input" data-field="type" data-cat="' + catIndex + '" data-item="' + itemIndex + '" data-option="' + optIndex + '"><option value="choices"' + (opt.type !== 'checkbox' ? ' selected' : '') + '>Choix</option><option value="checkbox"' + (opt.type === 'checkbox' ? ' selected' : '') + '>Supplement oui/non</option></select>' +
      '<label class="checkline"><input type="checkbox" data-field="required" data-cat="' + catIndex + '" data-item="' + itemIndex + '" data-option="' + optIndex + '"' + (opt.required ? ' checked' : '') + '> Requis</label>' +
      '<button class="small-action danger" type="button" data-action="remove-option" data-cat="' + catIndex + '" data-item="' + itemIndex + '" data-option="' + optIndex + '">Suppr.</button>' +
      '</div>' +
      input('Cle option', opt.key, { field: 'key', cat: catIndex, item: itemIndex, option: optIndex }) +
      choices +
      (opt.type === 'checkbox' ? '' : '<button class="small-action" type="button" data-action="add-choice" data-cat="' + catIndex + '" data-item="' + itemIndex + '" data-option="' + optIndex + '">+ Ajouter choix</button>') +
    '</div>';
  }
  function input(placeholder, value, meta) {
    const attrs = Object.entries(meta).map(([key, val]) => 'data-' + key + '="' + esc(val) + '"').join(' ');
    return '<input class="field-input" type="' + esc(meta.type || 'text') + '" placeholder="' + esc(placeholder) + '" value="' + esc(value) + '" ' + attrs + '>';
  }
  function indexes(el) {
    return { field: el.dataset.field, cat: num(el.dataset.cat), item: num(el.dataset.item), option: num(el.dataset.option), choice: num(el.dataset.choice) };
  }
  function num(value) { return value == null ? null : Number(value); }
  function target(state, ix) {
    let obj = state.categories[ix.cat];
    if (ix.item != null) obj = obj.items[ix.item];
    if (ix.option != null) obj = obj.options[ix.option];
    if (ix.choice != null) obj = obj.choices[ix.choice];
    return obj;
  }
  function onInput(builder, el) {
    const state = builders.get(builder);
    const ix = indexes(el);
    if (!ix.field || ix.cat == null) return;
    const obj = target(state, ix);
    if (!obj) return;
    obj[ix.field] = el.type === 'checkbox' ? el.checked : el.type === 'number' ? Number(el.value || 0) : el.value;
    if (ix.field === 'type') {
      if (obj.type === 'checkbox') obj.choices = [];
      if (obj.type === 'choices' && !obj.choices.length) obj.choices = [{ id: 'standard', label: 'Standard', price: 0 }];
      render(builder);
      return;
    }
    sync(builder);
  }
  function onAction(builder, button) {
    const state = builders.get(builder);
    const action = button.dataset.action;
    const ix = indexes(button);
    if (button.dataset.preset) state.categories = menuToState(PRESETS[button.dataset.preset]);
    if (action === 'add-cat') state.categories.push({ key: 'categorie-' + (state.categories.length + 1), label: 'Nouvelle categorie', items: [] });
    if (action === 'remove-cat') state.categories.splice(ix.cat, 1);
    if (action === 'add-item') state.categories[ix.cat].items.push({ id: 'article-' + (state.categories[ix.cat].items.length + 1), name: 'Nouvel article', basePrice: 0, description: '', image: '', options: [] });
    if (action === 'remove-item') state.categories[ix.cat].items.splice(ix.item, 1);
    if (action === 'add-option') state.categories[ix.cat].items[ix.item].options.push({ key: 'option-' + (state.categories[ix.cat].items[ix.item].options.length + 1), label: 'Nouvelle option', type: 'choices', required: false, price: 0, choices: [{ id: 'standard', label: 'Standard', price: 0 }] });
    if (action === 'remove-option') state.categories[ix.cat].items[ix.item].options.splice(ix.option, 1);
    if (action === 'add-choice') state.categories[ix.cat].items[ix.item].options[ix.option].choices.push({ id: 'choix-' + (state.categories[ix.cat].items[ix.item].options[ix.option].choices.length + 1), label: 'Nouveau choix', price: 0 });
    if (action === 'remove-choice') state.categories[ix.cat].items[ix.item].options[ix.option].choices.splice(ix.choice, 1);
    render(builder);
  }
  document.querySelectorAll('.restaurant-form').forEach((form) => {
    const builder = form.querySelector('[data-menu-builder]');
    const textarea = form.querySelector('.menu-json-input');
    if (!builder || !textarea) return;
    let parsed = {};
    try { parsed = JSON.parse(textarea.value || '{}'); } catch { parsed = {}; }
    const existing = menuToState(parsed);
    builders.set(builder, { textarea, categories: existing.length ? existing : menuToState(PRESETS[builder.dataset.defaultPreset || 'fastfood']) });
    render(builder);
    form.addEventListener('click', (event) => {
      const presetButton = event.target.closest('[data-preset]');
      if (!presetButton) return;
      event.preventDefault();
      onAction(builder, presetButton);
    });
    builder.addEventListener('click', (event) => {
      const button = event.target.closest('button');
      if (!button) return;
      if (!button.dataset.action && !button.dataset.preset) return;
      onAction(builder, button);
    });
    builder.addEventListener('input', (event) => onInput(builder, event.target));
    builder.addEventListener('change', (event) => onInput(builder, event.target));
    form.addEventListener('submit', () => sync(builder));
  });
})();
</script>
</body></html>
