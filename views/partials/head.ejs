<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'fr' %>" dir="<%= typeof langDir !== 'undefined' ? langDir : 'ltr' %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="theme-color" content="#090910">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="Collo">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>ColloExpress</title>
<link rel="manifest" href="/manifest.webmanifest">
<link rel="icon" type="image/png" sizes="192x192" href="/images/icons/icon-192.png">
<link rel="apple-touch-icon" href="/images/icons/icon-192.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="dns-prefetch" href="https://unpkg.com">
<link rel="dns-prefetch" href="https://upload.wikimedia.org">
<link rel="dns-prefetch" href="https://tile.openstreetmap.org">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css?v=app-push-1">
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %> <%= typeof isArabic !== 'undefined' && isArabic ? 'lang-ar' : 'lang-fr' %>">
<a class="lang-switch" href="/lang/<%= typeof langSwitchTarget !== 'undefined' ? langSwitchTarget : 'ar' %>" aria-label="Changer la langue">
  <%= typeof langSwitchLabel !== 'undefined' ? langSwitchLabel : 'AR' %>
</a>
<script>
window.COLLO_LANG = <%- JSON.stringify(typeof lang !== 'undefined' ? lang : 'fr') %>;
</script>
<script defer src="/js/i18n.js?v=app-push-1"></script>
<script defer src="/js/pwa.js?v=1"></script>
<script defer src="/js/push.js?v=app-push-1"></script>
