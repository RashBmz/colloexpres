DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR_SUPABASE_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_SSL=true
SESSION_SECRET=change-me-with-a-long-random-secret
TRUST_PROXY=1
PORT=3000
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=10000
PG_CONNECT_TIMEOUT_MS=10000
PG_STATEMENT_TIMEOUT_MS=10000
PG_QUERY_TIMEOUT_MS=10000
PG_MAX_USES=7500

# Notifications site / PWA
# Genere les deux cles avec: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@colloexpress.local

# Notifications app Android via Firebase Cloud Messaging
# Mets soit le JSON complet, soit le JSON encode en base64.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
